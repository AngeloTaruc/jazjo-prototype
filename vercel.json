{
  "version": 2,
  "functions": {
    "api/**/*.mjs": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/:path*"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/:path((?!api/).*)",
      "destination": "/public/:path"
    }
  ]
}
